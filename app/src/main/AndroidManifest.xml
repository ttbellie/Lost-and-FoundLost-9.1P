<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LostAndFound">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".CreateAdvertActivity"
            android:exported="false"
            android:label="@string/title_create_advert"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AdvertListActivity"
            android:exported="false"
            android:label="@string/title_all_items"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".AdvertDetailActivity"
            android:exported="false"
            android:label="@string/title_item_detail"
            android:parentActivityName=".AdvertListActivity" />

        <activity
            android:name=".MapActivity"
            android:exported="false"
            android:label="@string/title_map"
            android:parentActivityName=".MainActivity" />

    </application>

</manifest>
